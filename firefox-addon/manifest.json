{
  "manifest_version": 2,
  "name": "JDownloader",
  "version": "1.0.0",
  "description": "Click'N'Load support via JDownloader",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "tabs",
    "notifications",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "JDownloader"
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": ["jdcheck.js"],
  "applications": {
    "gecko": {
      "id": "jdownloader-web@local",
      "strict_min_version": "57.0"
    }
  }
}
