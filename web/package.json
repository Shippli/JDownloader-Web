{
  "name": "jdownloader-web",
  "type": "module",
  "version": "26.3.2",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:client": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "start": "bun src/server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/server/db/migrate.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@kobalte/core": "^0.13.11",
    "@unocss/reset": "^66.6.7",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@iconify-json/tabler": "^1.2.33",
    "@solidjs/router": "^0.16.1",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@unocss/preset-icons": "^66.6.7",
    "@unocss/preset-uno": "^66.6.7",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "solid-js": "^1.9.12",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "unocss": "^66.6.7",
    "vite": "^8.0.3",
    "vite-plugin-solid": "^2.11.11"
  }
}
